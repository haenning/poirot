{
  "name": "poirot",
  "displayName": "Poirot",
  "description": "Manage paraglide-js/inlang i18n translation keys from the sidebar",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haenning/poirot.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Poirot",
      "properties": {
        "poirot.autoConfigureCursorMcp": {
          "type": "boolean",
          "default": true,
          "description": "Write a poirot entry to ~/.cursor/mcp.json when the extension activates or the config path changes."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "poirot",
          "title": "Poirot",
          "icon": "images/iconoir--quote-message-solid.svg"
        }
      ]
    },
    "views": {
      "poirot": [
        {
          "type": "webview",
          "id": "poirot.sidebar",
          "name": "Poirot"
        }
      ]
    },
    "commands": [
      {
        "command": "poirot.newKey",
        "title": "Poirot: New Translation Key"
      },
      {
        "command": "poirot.goToKey",
        "title": "Poirot: Go To Key"
      },
      {
        "command": "poirot.editKey",
        "title": "Poirot: Edit Key"
      }
    ],
    "keybindings": [
      {
        "command": "poirot.newKey",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run compile && vitest run --config vitest.integration.config.ts",
    "test:e2e": "npm run compile && node test/e2e/runTests.js",
    "test:all": "npm test && npm run test:integration && npm run test:e2e",
    "test:bench": "tsx test/benchmark/run-load.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "proper-lockfile": "^4.1.2",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/vscode": "^1.120.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.6",
    "tsx": "^4.22.3",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
